# ── LLM Provider (OpenRouter recommended for AWS tools) ─
# PICOCLAW_PROVIDERS_OPENROUTER_API_KEY=sk-or-v1-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx

# ── AWS (required: S3 memory + MCP tools enabled by default) ─
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx

# ── Claw Cubed: S3 Memory (default backend) ─
# Required for S3: create bucket, then set:
# PICOCLAW_MEMORY_S3_BUCKET=my-clawcubed-memory
# PICOCLAW_MEMORY_S3_PREFIX=
# PICOCLAW_MEMORY_S3_REGION=

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo
