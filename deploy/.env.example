# Production env for Claw Cubed on a launched instance.
# Copy to .env or set in systemd / your launcher.

# ── AWS (required for S3 memory + MCP) ─────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# (or use IAM role on the instance)

# ── S3 memory (required when memory.backend=s3) ──────────────
PICOCLAW_MEMORY_S3_BUCKET=your-clawcubed-memory
# PICOCLAW_MEMORY_S3_PREFIX=
# PICOCLAW_MEMORY_S3_REGION=

# ── Cloudflare R2 memory (when memory.backend=r2) ───────────
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# (Also set memory.r2.bucket in config.json)

# ── LLM provider (set at least one) ─────────────────────────
# PICOCLAW_PROVIDERS_OPENROUTER_API_KEY=sk-or-v1-xxx
# PICOCLAW_PROVIDERS_ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx

# Config path: app reads ~/.picoclaw/config.json (create from config/config.example.json).
